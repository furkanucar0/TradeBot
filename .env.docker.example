# Docker/VPS dağıtımı için ortam değişkenleri (K-24).
# Kopyala: .env.docker  → değerleri doldur → git'e EKLEME (.gitignore'da).
#
#   docker compose --env-file .env.docker build
#   docker compose --env-file .env.docker up -d

# ── Binance USDT-M Futures ────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# ── Telegram uzaktan kontrol ──────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── API güvenliği (K-24) ──────────────────────────────────────────────────
# Rastgele üret: PowerShell -> [guid]::NewGuid().ToString("N") + [guid]::NewGuid().ToString("N")
#                Bash       -> openssl rand -hex 32
# Boş kalırsa API kimlik doğrulaması ATLANIR — VPS'te ASLA boş bırakma.
API_KEY=

# VPS'in dışa açık adresi (frontend + izleme buradan CORS yapar)
CORS_EXTRA_ORIGINS=http://SUNUCU_IP:5173

# ── Google girişi (K-26) — opsiyonel, dashboard'u tarayıcıdan kullananlar için
# GOOGLE_CLIENT_ID boşsa Google girişi tamamen devre dışı kalır (VITE_API_KEY
# ile eski statik-anahtar modu çalışmaya devam eder).
GOOGLE_CLIENT_ID=
# Virgülle ayrılmış, izinli Gmail adresleri (küçük/büyük harf önemsiz)
ALLOWED_EMAILS=
# Boş kalırsa süreç başına rastgele üretilir (restart = herkes yeniden giriş
# yapar). Kalıcı oturumlar için sabit bir değer verin: openssl rand -hex 32
SESSION_SECRET=

# ── Frontend build-time (Vite bunları JS bundle'ına GÖMER) ────────────────
# VITE_API_KEY burada AYRICA tanımlanmaz — docker-compose.yml build args'ta
# ${API_KEY}'i otomatik yeniden kullanır, elle kopyalamana gerek yok.
# Google Client ID build-time gömülmez — frontend her açılışta backend'in
# GET /auth/config'inden runtime'da okur (rebuild etmeden değiştirilebilir).
VITE_API_BASE_URL=http://SUNUCU_IP:8000

# ── Veritabanı (opsiyonel — boşsa backend/bot.sqlite varsayılan) ──────────
# DATABASE_PATH=

# Yalnızca Docker Desktop + Windows bind-mount (9p dosya sistemi, WSL2)
# kombinasyonunda gerekli: WAL modunun mmap/paylaşımlı-kilit mekanizmasını
# güvenilir desteklemiyor (K-24/K-25'te ölçüldü — 10/10 "disk I/O error").
# Native Linux VPS'te (ör. Ubuntu) GEREKMEZ, satırı silin/boş bırakın.
# SQLITE_JOURNAL_MODE=DELETE
