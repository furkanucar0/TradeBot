# Backend configuration
DATABASE_PATH=./backend/bot.sqlite
MODEL_PATH=./backend/model.bin
TIMEFRAME=5m
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,XRP/USDT
MAX_POSITIONS=5
TARGET_PROFIT_PCT=1.5
STOP_LOSS_PCT=1.0
SIGNAL_THRESHOLD=0.65
RETRAIN_INTERVAL_HOURS=24
LOOP_INTERVAL_SECONDS=30
PAPER_TRADE_SIZE=0.001

# Binance API keys (paper trading mode - not required for simulated orders)
BINANCE_API_KEY=
BINANCE_API_SECRET=
